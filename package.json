{
  "name": "tubeplayer",
  "version": "0.1.0",
  "description": "TubePlayer — YouTube Popup Player. Custom YouTube popup player library with fully custom controls, mobile optimization, and no YouTube UI.",
  "type": "module",
  "main": "dist/tubeplayer.cjs.js",
  "module": "dist/tubeplayer.es.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/tubeplayer.es.js",
      "require": "./dist/tubeplayer.cjs.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "src/index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --mode lib",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "prepublishOnly": "npm test && npm run build:lib"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hellomrma/tube-player.git"
  },
  "homepage": "https://github.com/hellomrma/tube-player#readme",
  "bugs": {
    "url": "https://github.com/hellomrma/tube-player/issues"
  },
  "keywords": [
    "youtube",
    "youtube-player",
    "youtube-popup",
    "youtube-popup-player",
    "youtube-modal",
    "youtube-embed",
    "youtube-iframe",
    "video-player",
    "popup-player",
    "video-popup",
    "custom-video-player",
    "custom-controls",
    "popup",
    "modal",
    "video",
    "player",
    "tubeplayer",
    "vanilla-js",
    "mobile-video"
  ]
}

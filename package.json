{
  "name": "tubeplayer",
  "version": "0.1.0",
  "description": "Vanilla JS custom YouTube popup player with fully custom controls and mobile optimization",
  "type": "module",
  "main": "dist/tubeplayer.cjs.js",
  "module": "dist/tubeplayer.es.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/tubeplayer.es.js",
      "require": "./dist/tubeplayer.cjs.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "src/index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --mode lib",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "license": "MIT",
  "keywords": [
    "youtube",
    "player",
    "popup",
    "modal",
    "video",
    "custom-controls",
    "tubeplayer"
  ]
}
